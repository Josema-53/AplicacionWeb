{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.7.4",
      "memory": 3008,
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/frontend/(.*)", "dest": "/frontend/$1" },
    { "src": "^/$", "dest": "/api/index.php" },
    { "src": "/(.+)", "dest": "/api/$1" }
  ]
}
